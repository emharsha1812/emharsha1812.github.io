---
layout: default
---

<!-- Global style for accent-color on checked checkboxes -->
<style>
  /* Targets any GFM-style task list checkbox */
  ul.task-list input[type="checkbox"]:checked {
    accent-color: aqua !important;
  }
  /* Scale down headings inside post body so H1 doesn't render at display size */
  article.post-content h1 { font-size: 1.75rem; margin-top: 2rem; }
  article.post-content h2 { font-size: 1.45rem; margin-top: 1.6rem; }
  article.post-content h3 { font-size: 1.2rem;  margin-top: 1.2rem; }
  article.post-content h4 { font-size: 1.05rem; margin-top: 1rem; }
</style>

{% assign year = page.date | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}

{% if page.series %}
  {% assign series_posts = site.posts | where: "series", page.series | sort: "series_part" %}
  {% assign series_total = series_posts | size %}
  {% assign series_prev = nil %}
  {% assign series_next = nil %}
  {% assign series_found = false %}
  {% for sp in series_posts %}
    {% if sp.url == page.url %}
      {% assign series_found = true %}
    {% elsif series_found and series_next == nil %}
      {% assign series_next = sp %}
    {% elsif series_found == false %}
      {% assign series_prev = sp %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

{% assign url_beginning = page.url | slice: 0, 6 %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-meta">
      Created in {{ page.date | date: '%B %d, %Y' }}
      {% if page.author %}by {{ page.author }}{% endif %}
      {% if page.last_updated %}, last updated in {{ page.last_updated | date: '%B %d, %Y' }}{% endif %}
      {% if page.meta %}• {{ page.meta }}{% endif %}
      {% if site.enable_blog_viewing %}
        &nbsp; &middot; &nbsp;
        <span id="busuanzi_container_page_pv">
          <i class="fa-regular fa-eye fa-sm"></i> <span id="busuanzi_value_page_pv"></span>
        </span>
      {% endif %}
    </p>
    <p class="post-tags">
      {% if url_beginning == '/blog/' %}
        <a href="{{ year | prepend: '/blog/' | prepend: site.baseurl}}"> <i class="fa-solid fa-calendar fa-sm"></i> {{ year }} </a>
      {% else %}
        <i class="fa-solid fa-calendar fa-sm"></i> {{ year }}
      {% endif %}
      {% if tags != '' %}
        &nbsp; &middot; &nbsp;
        {% for tag in page.tags %}
          {% if url_beginning == '/blog/' %}
            <a href="{{ tag | slugify | prepend: '/blog/tag/' | prepend: site.baseurl}}"> <i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}</a>
          {% else %}
            <i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}
          {% endif %}
          {% unless forloop.last %}
            &nbsp;
          {% endunless %}
        {% endfor %}
      {% endif %}

      {% if categories != '' %}
        &nbsp; &middot; &nbsp;
        {% for category in page.categories %}
          {% if url_beginning == '/blog/' %}
            <a href="{{ category | slugify | prepend: '/blog/category/' | prepend: site.baseurl}}">
              <i class="fa-solid fa-tag fa-sm"></i> {{ category -}}
            </a>
          {% else %}
            <i class="fa-solid fa-tag fa-sm"></i> {{ category }}
          {% endif %}
          {% unless forloop.last %}
            &nbsp;
          {% endunless %}
        {% endfor %}
      {% endif %}
    </p>

    {% if page.series %}
      <p class="post-meta series-label" style="margin-top: 0.4rem;">
        <i class="fa-solid fa-list-ol fa-sm"></i>
        {% if page.series_title %}{{ page.series_title }} &mdash; {% endif %}Part {{ page.series_part }} of {{ series_total }}
      </p>
    {% endif %}
  </header>

  <article class="post-content">
    {% if page.toc and page.toc.beginning %}
      <div id="table-of-contents">
        {% toc %}
      </div>
      <hr>
    {% endif %}
    <div id="markdown-content">
      {{ content }}
    </div>
  </article>

  {% if page.series and series_total > 1 %}
    <nav class="series-nav mt-4 pt-3" style="border-top: 1px solid var(--global-divider-color, #ddd);">
      <div class="row">
        <div class="col text-start">
          {% if series_prev %}
            <a href="{{ series_prev.url | relative_url }}">&larr; Part {{ series_prev.series_part }}: {{ series_prev.title }}</a>
          {% endif %}
        </div>
        <div class="col text-end">
          {% if series_next %}
            <a href="{{ series_next.url | relative_url }}">Part {{ series_next.series_part }}: {{ series_next.title }} &rarr;</a>
          {% endif %}
        </div>
      </div>
    </nav>
  {% endif %}

  {% if page.citation %}
    {% include citation.liquid %}
  {% endif %}

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.related_blog_posts.enabled %}
    {% if page.related_posts == null or page.related_posts %}
      {% include related_posts.liquid %}
    {% endif %}
  {% endif %}

  {% if site.enable_post_likes %}
    {% include post_likes.liquid %}
  {% endif %}

  {% if site.cusdis_app_id and site.cusdis_app_id != '' %}
    {% include cusdis.liquid %}
  {% endif %}

  {% if site.disqus_shortname and page.disqus_comments %}
    {% include disqus.liquid %}
  {% endif %}
  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>

<!-- JavaScript to remove the 'disabled' attribute from all checkboxes -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const checkboxes = document.querySelectorAll('.task-list-item-checkbox');
    checkboxes.forEach(checkbox => {
      checkbox.removeAttribute('disabled');
    });
  });
</script>
